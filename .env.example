# ─── Anthropic (required for Claude models) ──────────────
ANTHROPIC_API_HOST=api.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── OpenAI (required for GPT models) ────────────────────
# If using a unified endpoint (e.g. codex.alsa-llc.site), set both
# ANTHROPIC_API_HOST and OPENAI_API_HOST to the same host.
# OPENAI_API_HOST=api.openai.com
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_API_PATH=/v1/responses

# ─── Optional ─────────────────────────────────────────────
# ANTHROPIC_API_PATH=/v1/messages
# DEFAULT_MODEL=claude-sonnet-4-6
# MAX_TOKENS=16384

# ─── System prompt override ──────────────────────────────
# Replace Cascade's default system prompt with your own.
# Dynamic IDE context (tools, workspace rules, memories) is preserved.
# Hot-reloads on file change — no restart needed.
# SYSTEM_PROMPT_OVERRIDE=true
# SYSTEM_PROMPT_PATH=./prompts/system-prompt.md
