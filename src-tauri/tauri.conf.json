{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IDE BYOK",
  "version": "1.0.2",
  "identifier": "com.idebyok.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "IDE BYOK",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/ide-byok-proxy"],
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5QUZCOTkwNkJBNURGQ0IKUldUTDM2VnJrTG12K2ZKNURrWHA1a0toM1BXSDNQaGxVRXhrVHpyTkV2YTZnL3VvNmh0NzRWTkUK",
      "endpoints": [
        "https://github.com/soulvon/windsurf-byok/releases/latest/download/latest.json"
      ]
    }
  }
}
