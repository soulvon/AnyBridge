{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyBridge",
  "version": "0.3.1",
  "identifier": "com.anybridge.desktop",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "npm run build:ui",
    "beforeBuildCommand": "npm run build:ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AnyBridge",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "dangerousDisableAssetCspModification": ["script-src", "style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/anybridge-proxy"],
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/nsis/installer-hooks.nsh",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3MEEwQ0E3QTA3NzMwNUIKUldSYk1IZWdwd3dLTnprdDA4aTdFVkJUNEpKWW9PTVY0RmVWMCtCenFaU1poUUgrbmFNS1NxeGwK",
      "endpoints": [
        "https://github.com/soulvon/AnyBridge/releases/latest/download/latest.json"
      ]
    }
  }
}
