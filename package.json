{
  "name": "ide-byok",
  "version": "1.2.13",
  "description": "Hybrid proxy for IDE — intercepts chat, forwards everything else to Codeium",
  "type": "module",
  "main": "sidecar/proxy-entry.js",
  "scripts": {
    "start": "node sidecar/proxy-entry.js",
    "start:proxy": "node sidecar/hybrid-server.js",
    "start:inference": "node sidecar/inference-proxy.js",
    "start:both": "node sidecar/proxy-entry.js",
    "dev": "node --watch sidecar/proxy-entry.js",
    "dev:proxy": "node --watch sidecar/hybrid-server.js",
    "dev:inference": "node --watch sidecar/inference-proxy.js",
    "check:ui": "node scripts/check-ui.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:local": "tauri build --config src-tauri/tauri.local.conf.json"
  },
  "keywords": [
    "ide-byok",
    "codeium",
    "anthropic",
    "proxy",
    "connect-rpc",
    "protobuf",
    "reverse-engineering"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "jsdom": "^27.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
